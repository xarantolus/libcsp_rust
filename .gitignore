# ── Rust / Cargo ──────────────────────────────────────────────────────────────
/target/
# Cargo.lock is intentionally omitted for libraries (let consumers control it).
# Uncomment the next line if this is a binary crate:
# Cargo.lock

# ── C build artefacts ─────────────────────────────────────────────────────────
*.a
*.so
*.dylib
*.dll
*.o
*.d

# ── bindgen / cc cache ────────────────────────────────────────────────────────
# Generated files live in target/; nothing to ignore here.

# ── libcsp vendored source ────────────────────────────────────────────────────
# Tracked as a git submodule — the directory itself is NOT ignored.
# The waf build artefacts inside it are:
libcsp/build/
libcsp/.waf*/
libcsp/.lock-waf*
# csp_autoconfig.h is generated by our build.rs (into OUT_DIR) or by waf
# (into libcsp/include/csp/). Ignore the waf-generated copy.
libcsp/include/csp/csp_autoconfig.h

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
*.key
